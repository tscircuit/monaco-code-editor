{
	"name": "monaco-code-editor",
	"module": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"type": "module",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"default": "./dist/index.js"
		}
	},
	"scripts": {
		"build": "bun run build:lib",
		"build:lib": "tsc --noEmit && tsup src/index.ts --format esm --dts --external react,react-dom,@monaco-editor/react,monaco-editor,@typescript/ata,typescript",
		"dev": "cosmos",
		"cosmos": "cosmos",
		"cosmos:export": "cosmos-export",
		"format": "biome format . --write",
		"format:check": "biome format .",
		"typecheck": "tsc --noEmit"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.5.1",
		"@tailwindcss/vite": "^4.3.1",
		"@types/bun": "latest",
		"@types/react": "^19.2.17",
		"@types/react-dom": "^19.2.3",
		"@vitejs/plugin-react": "^6.0.3",
		"react": "^19.2.7",
		"react-cosmos": "^7.3.0",
		"react-cosmos-plugin-vite": "^7.3.0",
		"react-dom": "^19.2.7",
		"tailwindcss": "^4.3.1",
		"tsup": "^8.5.1",
		"vite": "^8.1.0"
	},
	"peerDependencies": {
		"react": ">=18",
		"react-dom": ">=18"
	},
	"dependencies": {
		"@monaco-editor/react": "^4.7.0",
		"@shikijs/monaco": "^4.3.0",
		"@shikijs/vscode-textmate": "^10.0.2",
		"@typescript/ata": "^0.9.8",
		"monaco-editor": "^0.55.1",
		"shiki": "^4.3.0",
		"typescript": "^6.0.3"
	}
}
