{
	"name": "monaco-code-editor",
	"module": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"type": "module",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"default": "./dist/index.js"
		}
	},
	"scripts": {
		"build": "bun run build:lib",
		"build:lib": "tsc --noEmit && tsup src/index.ts --format esm --dts --external react,react-dom,@monaco-editor/react,monaco-editor,@typescript/ata,typescript,@tscircuit/runframe",
		"dev": "cosmos",
		"cosmos": "cosmos",
		"cosmos:export": "cosmos-export",
		"format": "biome format . --write",
		"format:check": "biome format .",
		"typecheck": "tsc --noEmit"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.5.1",
		"@radix-ui/react-alert-dialog": "^1.1.17",
		"@radix-ui/react-checkbox": "^1.3.5",
		"@radix-ui/react-dialog": "^1.1.17",
		"@radix-ui/react-dropdown-menu": "^2.1.18",
		"@radix-ui/react-icons": "^1.3.2",
		"@radix-ui/react-popover": "^1.1.17",
		"@radix-ui/react-slot": "^1.3.0",
		"@radix-ui/react-tabs": "^1.1.15",
		"@radix-ui/react-tooltip": "^1.2.10",
		"@tailwindcss/vite": "^4.3.1",
		"@tscircuit/3d-viewer": "^0.0.571",
		"@tscircuit/assembly-viewer": "^0.0.6",
		"@tscircuit/core": "^0.0.1362",
		"@tscircuit/create-snippet-url": "^0.0.14",
		"@tscircuit/internal-dynamic-import": "^0.0.7",
		"@tscircuit/pcb-viewer": "^1.11.374",
		"@tscircuit/props": "^0.0.557",
		"@tscircuit/runframe": "^0.0.2128",
		"@tscircuit/schematic-viewer": "^2.0.67",
		"@tscircuit/solver-utils": "^0.0.19",
		"@types/bun": "latest",
		"@types/react": "^19.2.17",
		"@types/react-dom": "^19.2.3",
		"@vitejs/plugin-react": "^6.0.3",
		"circuit-json-to-bom-csv": "^0.0.9",
		"circuit-json-to-pnp-csv": "^0.0.8",
		"class-variance-authority": "^0.7.1",
		"clsx": "^2.1.1",
		"cmdk": "^1.1.1",
		"debug": "^4.4.3",
		"fflate": "^0.8.3",
		"fuse.js": "^7.4.2",
		"jszip": "^3.10.1",
		"ky": "^2.0.2",
		"lucide-react": "^1.21.0",
		"marked": "^18.0.5",
		"minimatch": "^10.2.5",
		"posthog-js": "^1.395.0",
		"react": "^19.2.7",
		"react-cosmos": "^7.3.0",
		"react-cosmos-plugin-vite": "^7.3.0",
		"react-dom": "^19.2.7",
		"react-error-boundary": "^6.1.2",
		"react-hot-toast": "^2.6.0",
		"react-query": "^3.39.3",
		"tailwind-merge": "^3.6.0",
		"tailwindcss": "^4.3.1",
		"three": "^0.185.0",
		"tsup": "^8.5.1",
		"vite": "^8.1.0",
		"zustand": "^5.0.14"
	},
	"peerDependencies": {
		"react": ">=18",
		"react-dom": ">=18"
	},
	"dependencies": {
		"@monaco-editor/react": "^4.7.0",
		"@shikijs/monaco": "^4.3.0",
		"@shikijs/vscode-textmate": "^10.0.2",
		"@typescript/ata": "^0.9.8",
		"monaco-editor": "^0.55.1",
		"shiki": "^4.3.0",
		"typescript": "^6.0.3"
	}
}
