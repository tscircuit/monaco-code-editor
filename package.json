{
	"name": "@tscircuit/monaco-code-editor",
	"version": "0.0.5",
	"repository": "https://github.com/tscircuit/monaco-code-editor",
	"publishConfig": {
		"registry": "https://npm.pkg.github.com"
	},
	"files": [
		"dist"
	],
	"main": "./dist/index.js",
	"module": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"type": "module",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js",
			"default": "./dist/index.js"
		}
	},
	"scripts": {
		"build": "tsc -p tsconfig.lib.json --noEmit && tsup src/index.ts --tsconfig tsconfig.lib.json --format esm --dts --clean --external react,react-dom,@monaco-editor/react,monaco-editor,@typescript/ata,typescript",
		"dev": "cosmos",
		"cosmos": "cosmos",
		"cosmos:export": "cosmos-export",
		"format": "biome format . --write",
		"format:check": "biome format .",
		"prepare": "bun run build",
		"typecheck": "tsc --noEmit"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.5.1",
		"@radix-ui/react-icons": "^1.3.2",
		"@tscircuit/3d-viewer": "^0.0.571",
		"@tscircuit/assembly-viewer": "^0.0.6",
		"@tscircuit/create-snippet-url": "^0.0.14",
		"@tscircuit/image-utils": "^0.0.8",
		"@tscircuit/pcb-viewer": "^1.11.374",
		"@tscircuit/props": "^0.0.557",
		"@tscircuit/runframe": "^0.0.2128",
		"@tscircuit/schematic-viewer": "^2.0.67",
		"@types/bun": "latest",
		"@types/react": "^19.2.17",
		"@types/react-dom": "^19.2.3",
		"@vitejs/plugin-react": "^6.0.3",
		"autoprefixer": "^10.4.20",
		"circuit-json": "^0.0.446",
		"circuit-json-to-bom-csv": "^0.0.9",
		"circuit-json-to-pnp-csv": "^0.0.8",
		"class-variance-authority": "^0.7.1",
		"clsx": "^2.1.1",
		"cmdk": "^1.1.1",
		"fuse.js": "^7.4.2",
		"jszip": "^3.10.1",
		"ky": "^1.7.5",
		"lucide-react": "^1.21.0",
		"postcss": "^8.4.47",
		"posthog-js": "^1.253.4",
		"react": "^19.2.7",
		"react-cosmos": "^7.3.0",
		"react-cosmos-plugin-vite": "^7.3.0",
		"react-dom": "^19.2.7",
		"react-error-boundary": "^6.1.2",
		"react-hot-toast": "^2.6.0",
		"react-query": "^3.39.3",
		"tailwind-merge": "^3.6.0",
		"tailwindcss": "^3.4.13",
		"tailwindcss-animate": "^1.0.7",
		"tsup": "^8.5.1",
		"vite": "^8.1.0",
		"zustand": "^5.0.14"
	},
	"peerDependencies": {
		"react": ">=18",
		"react-dom": ">=18"
	},
	"dependencies": {
		"@fontsource-variable/geist": "^5.2.9",
		"@monaco-editor/react": "^4.7.0",
		"@shikijs/monaco": "^4.3.0",
		"@shikijs/vscode-textmate": "^10.0.2",
		"@typescript/ata": "^0.9.8",
		"monaco-editor": "^0.55.1",
		"radix-ui": "^1.6.0",
		"shiki": "^4.3.0",
		"typescript": "^6.0.3"
	}
}
